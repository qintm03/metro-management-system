<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.mapper.MessagesMapper">

    <sql id="Base_Column_List">
        id, userid, username, avatarurl, content, cpicture, reply, rpicture, addtime
    </sql>

    <select id="selectByCondition" resultType="com.example.springboot.entity.Messages">
        SELECT
        <include refid="Base_Column_List"/>
        FROM messages
        <where>
            <if test="userid != null">
                AND userid = #{userid}
            </if>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="content != null and content != ''">
                AND content LIKE CONCAT('%', #{content}, '%')
            </if>
            <if test="reply != null and reply != ''">
                AND reply LIKE CONCAT('%', #{reply}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>
