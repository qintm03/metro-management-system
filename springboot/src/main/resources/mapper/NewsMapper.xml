<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.mapper.NewsMapper">

    <sql id="Base_Column_List">
        id, title, introduction, picture, content, addtime
    </sql>

    <select id="selectByCondition" resultType="com.example.springboot.entity.News">
        SELECT
        <include refid="Base_Column_List"/>
        FROM news
        <where>
            <if test="title != null and title != ''">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
            <if test="introduction != null and introduction != ''">
                AND introduction LIKE CONCAT('%', #{introduction}, '%')
            </if>
            <if test="content != null and content != ''">
                AND content LIKE CONCAT('%', #{content}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>
