<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.mapper.StoreupMapper">

    <sql id="Base_Column_List">
        id, userid, refid, tablename, name, picture, type, inteltype, remark, addtime
    </sql>

    <select id="selectByCondition" resultType="com.example.springboot.entity.Storeup">
        SELECT
        <include refid="Base_Column_List"/>
        FROM storeup
        <where>
            <if test="userid != null">
                AND userid = #{userid}
            </if>
            <if test="refid != null">
                AND refid = #{refid}
            </if>
            <if test="tablename != null and tablename != ''">
                AND tablename = #{tablename}
            </if>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>
