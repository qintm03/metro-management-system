{
  "name": "metro-management-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "concurrently \"npm run start:backend\" \"npm run dev\"",
    "start:backend": "cd ../springboot && mvn spring-boot:run",
    "start:all": "concurrently \"npm run start:backend\" \"npm run dev\" --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\""
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@arcgis/core": "^4.34.8",
    "axios": "^1.13.2",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.0",
    "v-scale-screen": "^2.3.0",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "concurrently": "^9.0.0",
    "vite": "^7.2.4"
  }
}
