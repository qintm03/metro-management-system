<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.mapper.DiscusschecixianluMapper">

    <sql id="Base_Column_List">
        id, refid, userid, avatarurl, nickname, content, reply, addtime
    </sql>

    <select id="selectByCondition" resultType="com.example.springboot.entity.Discusschecixianlu">
        SELECT
        <include refid="Base_Column_List"/>
        FROM discusschecixianlu
        <where>
            <if test="refid != null">
                AND refid = #{refid}
            </if>
            <if test="userid != null">
                AND userid = #{userid}
            </if>
            <if test="nickname != null and nickname != ''">
                AND nickname LIKE CONCAT('%', #{nickname}, '%')
            </if>
            <if test="content != null and content != ''">
                AND content LIKE CONCAT('%', #{content}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>
